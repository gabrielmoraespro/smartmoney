# ===================================================================
# SmartMoney - Variáveis de ambiente
# ===================================================================

# ─── Supabase (Frontend - VITE_) ───────────────────────────────────
VITE_SUPABASE_URL=https://seu-projeto.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ... # ⚠️ Deve ser ANON key (NUNCA service_role)

# ─── Supabase (Server Only - Netlify Functions) ────────────────────
# Pode repetir a mesma URL do VITE_SUPABASE_URL
SUPABASE_URL=https://seu-projeto.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ... # ⚠️ NUNCA expor no frontend

# ─── Pluggy ─────────────────────────────────────────────────────────
# VITE_PLUGGY_CLIENT_ID é opcional (telemetria/debug de frontend)
VITE_PLUGGY_CLIENT_ID=seu_client_id
PLUGGY_CLIENT_ID=seu_client_id
PLUGGY_CLIENT_SECRET=seu_client_secret

# ─── Stripe ─────────────────────────────────────────────────────────
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_... # ⚠️ NUNCA expor no frontend
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO_MONTHLY=price_1T6ef9EmHzv0i1aVwxx1QM9p

# ─── App / Functions ────────────────────────────────────────────────
APP_URL=https://smartmoney.app
# No local com Netlify Dev geralmente não precisa alterar:
VITE_FUNCTIONS_BASE_URL=/.netlify/functions
# Se rodar frontend separado das functions:
# VITE_FUNCTIONS_BASE_URL=http://localhost:8888/.netlify/functions
